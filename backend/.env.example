# Copia este archivo como .env y rellena con tus valores

# ================================
# DATABASE - NEON POSTGRESQL
# ================================
# Obtener en: https://console.neon.tech/
# Formato: postgresql://user:password@host/dbname?sslmode=require

DATABASE_URL=postgresql://user:password@ep-xyz123.us-east-1.neon.tech/producers_go?sslmode=require

# ================================
# SERVIDOR
# ================================
PORT=5000
NODE_ENV=development

# ================================
# EMAILS (SendGrid - Próximo)
# ================================
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=noreply@producersgo.com

# ================================
# SEGURIDAD (Próximo)
# ================================
# JWT_SECRET=your_jwt_secret_key_here
# API_KEY=your_api_key_here

# ================================
# FRONTEND
# ================================
FRONTEND_URL=http://localhost:3000
